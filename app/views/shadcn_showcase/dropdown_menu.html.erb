<main class="mx-auto max-w-7xl px-6 py-10">
  <header class="mb-8">
    <%= link_to "\u2190 Back", root_path, class: "text-sm text-zinc-600 hover:text-zinc-900" %>
    <h1 class="mt-2 text-3xl font-semibold tracking-tight"><%= @component.page_title %></h1>
    <p class="mt-2 text-sm text-zinc-600"><%= @component.page_description %></p>
  </header>

  <section class="grid gap-6 lg:grid-cols-2">
    <article class="rounded-xl border border-zinc-200 bg-white p-6 shadow-sm">
      <h2 class="mb-4 text-sm font-semibold uppercase tracking-wide text-zinc-500">Source (React + shadcn)</h2>
      <div data-react="shadcn-dropdown-menu-demo" class="rounded-lg border border-dashed border-zinc-300 p-6"></div>
    </article>

    <article class="rounded-xl border border-zinc-200 bg-white p-6 shadow-sm">
      <h2 class="mb-4 text-sm font-semibold uppercase tracking-wide text-zinc-500">Converted (Rails + Tailwind + Stimulus)</h2>

      <div class="rounded-lg border border-dashed border-zinc-300 p-6">
        <div data-controller="dropdown-menu-preview" class="sc-dropdown-menu">
          <button
            type="button"
            data-action="dropdown-menu-preview#toggle"
            data-dropdown-menu-preview-target="trigger"
            class="sc-dropdown-menu__trigger"
            aria-controls="sc-dropdown-menu-content"
            aria-haspopup="menu"
          >
            Open menu
          </button>

          <div
            id="sc-dropdown-menu-content"
            data-dropdown-menu-preview-target="content"
            class="sc-dropdown-menu__content hidden"
            role="menu"
          >
            <div class="sc-dropdown-menu__label">My Account</div>
            <div class="sc-dropdown-menu__separator"></div>

            <button type="button" data-action="dropdown-menu-preview#close" class="sc-dropdown-menu__item" role="menuitem">
              Profile
            </button>
            <button type="button" data-action="dropdown-menu-preview#close" class="sc-dropdown-menu__item" role="menuitem">
              Billing
            </button>
            <button type="button" data-action="dropdown-menu-preview#close" class="sc-dropdown-menu__item" role="menuitem">
              Settings
            </button>

            <div class="sc-dropdown-menu__separator"></div>

            <button type="button" data-action="dropdown-menu-preview#close" class="sc-dropdown-menu__item" role="menuitem">
              Log out
            </button>
          </div>
        </div>
      </div>
    </article>
  </section>
</main>
