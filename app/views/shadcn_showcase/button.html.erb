<main class="mx-auto max-w-7xl px-6 py-10" data-controller="button-preview">
  <header class="mb-8">
    <%= link_to "\u2190 Back", root_path, class: "text-sm text-zinc-600 hover:text-zinc-900" %>
    <h1 class="mt-2 text-3xl font-semibold tracking-tight"><%= @component.page_title %></h1>
    <p class="mt-2 text-sm text-zinc-600"><%= @component.page_description %></p>
  </header>

  <section class="grid gap-6 lg:grid-cols-2">
    <article class="rounded-xl border border-zinc-200 bg-white p-6 shadow-sm">
      <h2 class="mb-4 text-sm font-semibold uppercase tracking-wide text-zinc-500">Source (React + shadcn)</h2>
      <div data-react="shadcn-button-demo" class="rounded-lg border border-dashed border-zinc-300 p-6"></div>
    </article>

    <article class="rounded-xl border border-zinc-200 bg-white p-6 shadow-sm">
      <h2 class="mb-4 text-sm font-semibold uppercase tracking-wide text-zinc-500">Converted (Rails + Tailwind + Stimulus)</h2>

      <!-- CODE:converted:start -->
      <div class="rounded-lg border border-dashed border-zinc-300 p-6">
        <div class="mb-4 flex items-center gap-3">
          <button type="button" data-action="button-preview#toggleDisabled" class="sc-button sc-button--outline sc-button--sm">
            Toggle default disabled
          </button>
        </div>

        <div class="grid gap-3">
          <p class="text-xs font-semibold uppercase tracking-wide text-zinc-500">BEM-like class composition</p>
          <div class="flex flex-wrap items-center gap-3">
            <button type="button" data-button-preview-target="button" class="sc-button sc-button--default">Default</button>
            <button type="button" class="sc-button sc-button--default sc-button--sm">Small</button>
            <button type="button" class="sc-button sc-button--default sc-button--lg">Large</button>
            <button type="button" class="sc-button sc-button--default sc-button--icon" aria-label="Add item">+</button>
            <button type="button" class="sc-button sc-button--secondary sc-button--sm">Secondary / Small</button>
            <button type="button" class="sc-button sc-button--outline sc-button--lg">Outline / Large</button>
            <button type="button" class="sc-button sc-button--destructive sc-button--sm">Destructive / Small</button>
          </div>
        </div>
      </div>
      <!-- CODE:converted:end -->
    </article>
  </section>

  <section class="mt-6 grid gap-6 lg:grid-cols-2">
    <%= render "shared/code_panel", title: "Source Code (React)", code: @source_code %>
    <%= render "shared/code_panel", title: "Converted Code (ERB)", code: @converted_code %>
  </section>
</main>
