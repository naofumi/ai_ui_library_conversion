<main class="mx-auto max-w-7xl px-6 py-10">
  <header class="mb-8">
    <%= link_to "\u2190 Back", root_path, class: "text-sm text-zinc-600 hover:text-zinc-900" %>
    <h1 class="mt-2 text-3xl font-semibold tracking-tight"><%= @component.page_title %></h1>
    <p class="mt-2 text-sm text-zinc-600"><%= @component.page_description %></p>
  </header>

  <section class="grid gap-6 lg:grid-cols-2">
    <article class="rounded-xl border border-zinc-200 bg-white p-6 shadow-sm">
      <h2 class="mb-4 text-sm font-semibold uppercase tracking-wide text-zinc-500">Source (React + shadcn)</h2>
      <div data-react="shadcn-card-demo" class="rounded-lg border border-dashed border-zinc-300 p-6"></div>
    </article>

    <article class="rounded-xl border border-zinc-200 bg-white p-6 shadow-sm">
      <h2 class="mb-4 text-sm font-semibold uppercase tracking-wide text-zinc-500">Converted (Rails + Tailwind)</h2>
      <div class="sc-card">
        <div class="sc-card__header">
          <h3 class="sc-card__title">Card Title</h3>
          <p class="sc-card__description">Card description text that explains content at a glance.</p>
        </div>

        <div class="sc-card__content">
          <div class="sc-card__body-block">Body content area for converted component parity checks.</div>
        </div>

        <div class="sc-card__footer">
          <button type="button" class="sc-button sc-button--default sc-button--sm">Action</button>
        </div>
      </div>
    </article>
  </section>
</main>
