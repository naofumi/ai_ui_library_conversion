<main class="mx-auto max-w-7xl px-6 py-10" data-controller="button-preview">
  <header class="mb-8">
    <%= link_to "\u2190 Back", root_path, class: "text-sm text-zinc-600 hover:text-zinc-900" %>
    <h1 class="mt-2 text-3xl font-semibold tracking-tight"><%= @component.page_title %></h1>
    <p class="mt-2 text-sm text-zinc-600"><%= @component.page_description %></p>
  </header>

  <section class="grid gap-6 lg:grid-cols-2">
    <article class="rounded-xl border border-zinc-200 bg-white p-6 shadow-sm">
      <h2 class="mb-4 text-sm font-semibold uppercase tracking-wide text-zinc-500">Source (React + shadcn)</h2>
      <div data-react="shadcn-button-demo" class="rounded-lg border border-dashed border-zinc-300 p-6"></div>
    </article>

    <article class="rounded-xl border border-zinc-200 bg-white p-6 shadow-sm">
      <h2 class="mb-4 text-sm font-semibold uppercase tracking-wide text-zinc-500">Converted (Rails + Tailwind + Stimulus)</h2>

      <div class="mb-4 flex items-center gap-3">
        <button type="button" data-action="button-preview#toggleDisabled" class="c-button c-button--outline c-button--sm">
          Toggle default disabled
        </button>
      </div>

      <div class="grid gap-3">
        <p class="text-xs font-semibold uppercase tracking-wide text-zinc-500">BEM-like class composition (ERB)</p>
        <div class="flex flex-wrap items-center gap-3">
          <button type="button" data-button-preview-target="button" class="c-button c-button--default">Default</button>
          <button type="button" class="c-button c-button--default c-button--sm">Small</button>
          <button type="button" class="c-button c-button--default c-button--lg">Large</button>
          <button type="button" class="c-button c-button--default c-button--icon" aria-label="Add item">+</button>
          <button type="button" class="c-button c-button--secondary c-button--sm">Secondary / Small</button>
          <button type="button" class="c-button c-button--outline c-button--lg">Outline / Large</button>
          <button type="button" class="c-button c-button--destructive c-button--sm">Destructive / Small</button>
          <button type="button" class="c-button c-button--ghost c-button--sm">Ghost / Small</button>
          <button type="button" class="c-button c-button--link c-button--lg">Link / Large</button>
        </div>
      </div>
    </article>
  </section>
</main>
