<main class="mx-auto max-w-7xl px-6 py-10" data-controller="dialog-preview" data-action="keydown@window->dialog-preview#closeOnEscape">
  <header class="mb-8">
    <%= link_to "\u2190 Back", root_path, class: "text-sm text-zinc-600 hover:text-zinc-900" %>
    <h1 class="mt-2 text-3xl font-semibold tracking-tight">Dialog Conversion</h1>
    <p class="mt-2 text-sm text-zinc-600">Compare shadcn dialog structure and open/close behavior.</p>
  </header>

  <section class="grid gap-6 lg:grid-cols-2">
    <article class="rounded-xl border border-zinc-200 bg-white p-6 shadow-sm">
      <h2 class="mb-4 text-sm font-semibold uppercase tracking-wide text-zinc-500">Source (React + shadcn)</h2>
      <div data-react="shadcn-dialog-demo" class="rounded-lg border border-dashed border-zinc-300 p-6"></div>
    </article>

    <article class="rounded-xl border border-zinc-200 bg-white p-6 shadow-sm">
      <h2 class="mb-4 text-sm font-semibold uppercase tracking-wide text-zinc-500">Converted (Rails + Tailwind + Stimulus)</h2>

      <button type="button" data-action="dialog-preview#open" class="inline-flex h-9 items-center justify-center gap-2 whitespace-nowrap rounded-md bg-zinc-900 px-4 py-2 text-sm font-medium text-white shadow-xs transition-all hover:bg-zinc-800 focus-visible:ring-2 focus-visible:ring-zinc-400">
        Edit profile
      </button>

      <div data-dialog-preview-target="overlay" data-action="click->dialog-preview#closeOnBackdrop" class="fixed inset-0 z-50 hidden bg-black/50">
        <div class="grid min-h-full place-items-center p-4">
          <div role="dialog" aria-modal="true" class="relative grid w-full max-w-lg gap-4 rounded-lg border border-zinc-200 bg-white p-6 shadow-lg">
            <button type="button" data-action="dialog-preview#close" aria-label="Close dialog" class="absolute top-4 right-4 inline-flex size-8 items-center justify-center rounded-md border border-zinc-200 bg-white text-zinc-900 shadow-xs transition-all hover:bg-zinc-100 focus-visible:ring-2 focus-visible:ring-zinc-400">
              ×
            </button>

            <div class="flex flex-col gap-2 text-left">
              <h3 class="text-lg leading-none font-semibold text-zinc-950">Edit profile</h3>
              <p class="text-sm text-zinc-600">Make changes to your profile here. Click save when you're done.</p>
            </div>

            <div class="grid gap-3">
              <div class="grid gap-2">
                <label for="rails-name" class="text-sm font-medium text-zinc-900">Name</label>
                <input id="rails-name" type="text" value="Pedro Duarte" class="flex h-9 w-full min-w-0 rounded-md border border-zinc-200 bg-white px-3 py-1 text-sm text-zinc-950 shadow-xs outline-none transition-all placeholder:text-zinc-500 focus-visible:ring-2 focus-visible:ring-zinc-400">
              </div>

              <div class="grid gap-2">
                <label for="rails-username" class="text-sm font-medium text-zinc-900">Username</label>
                <input id="rails-username" type="text" value="@peduarte" class="flex h-9 w-full min-w-0 rounded-md border border-zinc-200 bg-white px-3 py-1 text-sm text-zinc-950 shadow-xs outline-none transition-all placeholder:text-zinc-500 focus-visible:ring-2 focus-visible:ring-zinc-400">
              </div>
            </div>

            <div class="flex flex-col-reverse gap-2 sm:flex-row sm:justify-end">
              <button type="button" data-action="dialog-preview#close" class="rounded-md border border-zinc-200 bg-white px-3 py-2 text-sm font-medium text-zinc-900 shadow-xs transition-all hover:bg-zinc-100 focus-visible:ring-2 focus-visible:ring-zinc-400">
                Cancel
              </button>
              <button type="button" data-action="dialog-preview#close" class="inline-flex h-9 items-center justify-center gap-2 whitespace-nowrap rounded-md bg-zinc-900 px-4 py-2 text-sm font-medium text-white shadow-xs transition-all hover:bg-zinc-800 focus-visible:ring-2 focus-visible:ring-zinc-400">
                Save changes
              </button>
            </div>
          </div>
        </div>
      </div>
    </article>
  </section>
</main>
