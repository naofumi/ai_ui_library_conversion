<main class="mx-auto max-w-7xl px-6 py-10" data-controller="button-preview">
  <header class="mb-8">
    <%= link_to "\u2190 Back", mui_path, class: "text-sm text-zinc-600 hover:text-zinc-900" %>
    <h1 class="mt-2 text-3xl font-semibold tracking-tight"><%= @component.page_title %></h1>
    <p class="mt-2 text-sm text-zinc-600"><%= @component.page_description %></p>
  </header>

  <section class="grid gap-6 lg:grid-cols-2">
    <article class="rounded-xl border border-zinc-200 bg-white p-6 shadow-sm">
      <h2 class="mb-4 text-sm font-semibold uppercase tracking-wide text-zinc-500">Source (React + MUI)</h2>
      <div data-react="mui-button-demo" class="rounded-lg border border-dashed border-zinc-300 p-6"></div>
    </article>

    <article class="rounded-xl border border-zinc-200 bg-white p-6 shadow-sm">
      <h2 class="mb-4 text-sm font-semibold uppercase tracking-wide text-zinc-500">Converted (Rails + Tailwind + Stimulus)</h2>

      <div class="mb-4 flex items-center gap-3">
        <button type="button" data-action="button-preview#toggleDisabled" class="mc-button mc-button--outlined mc-button--sm">
          Toggle default disabled
        </button>
      </div>

      <div class="grid gap-3">
        <p class="text-xs font-semibold uppercase tracking-wide text-zinc-500">BEM-like class composition (ERB)</p>
        <div class="flex flex-wrap items-center gap-3">
          <button type="button" data-button-preview-target="button" class="mc-button mc-button--contained">Contained</button>
          <button type="button" class="mc-button mc-button--outlined">Outlined</button>
          <button type="button" class="mc-button mc-button--text">Text</button>
          <button type="button" class="mc-button mc-button--contained mc-button--sm">Contained / Small</button>
          <button type="button" class="mc-button mc-button--contained mc-button--lg">Contained / Large</button>
          <button type="button" class="mc-button mc-button--outlined mc-button--sm">Outlined / Small</button>
          <button type="button" class="mc-button mc-button--error mc-button--sm">Error / Small</button>
        </div>
      </div>
    </article>
  </section>
</main>
