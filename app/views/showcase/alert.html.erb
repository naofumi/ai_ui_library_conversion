<main class="mx-auto max-w-7xl px-6 py-10" data-controller="alert-preview">
  <header class="mb-8">
    <%= link_to "\u2190 Back", root_path, class: "text-sm text-zinc-600 hover:text-zinc-900" %>
    <h1 class="mt-2 text-3xl font-semibold tracking-tight">Alert Conversion</h1>
    <p class="mt-2 text-sm text-zinc-600">Compare informational alert styling and dismiss interaction.</p>
  </header>

  <section class="grid gap-6 lg:grid-cols-2">
    <article class="rounded-xl border border-zinc-200 bg-white p-6 shadow-sm">
      <h2 class="mb-4 text-sm font-semibold uppercase tracking-wide text-zinc-500">Source (React)</h2>
      <div id="react-shadcn-alert-demo" class="rounded-lg border border-dashed border-zinc-300 p-6"></div>
    </article>

    <article class="rounded-xl border border-zinc-200 bg-white p-6 shadow-sm">
      <h2 class="mb-4 text-sm font-semibold uppercase tracking-wide text-zinc-500">Converted (Rails + Tailwind + Stimulus)</h2>
      <div class="mb-4">
        <button type="button" data-action="alert-preview#reset" class="rounded-md border border-zinc-300 px-3 py-2 text-sm font-medium text-zinc-700 hover:bg-zinc-50">Restore alert</button>
      </div>

      <div data-alert-preview-target="alert" class="max-w-lg rounded-xl border border-amber-200 bg-amber-50 p-4 text-amber-900">
        <div class="flex items-start justify-between gap-3">
          <div class="flex items-start gap-3">
            <div class="mt-0.5 h-2.5 w-2.5 rounded-full bg-amber-500"></div>
            <div>
              <h3 class="text-sm font-semibold">Heads up</h3>
              <p class="mt-1 text-sm text-amber-800">This alert demonstrates an informational state with a dismiss action.</p>
            </div>
          </div>
          <button type="button" data-action="alert-preview#dismiss" class="rounded-md px-2 py-1 text-xs font-medium text-amber-900 hover:bg-amber-100">Dismiss</button>
        </div>
      </div>
    </article>
  </section>
</main>
