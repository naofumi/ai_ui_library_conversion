<main class="mx-auto max-w-7xl px-6 py-10" data-controller="dialog-preview" data-action="keydown@window->dialog-preview#closeOnEscape">
  <header class="mb-8">
    <%= link_to "\u2190 Back", root_path, class: "text-sm text-zinc-600 hover:text-zinc-900" %>
    <h1 class="mt-2 text-3xl font-semibold tracking-tight"><%= @component.page_title %></h1>
    <p class="mt-2 text-sm text-zinc-600"><%= @component.page_description %></p>
  </header>

  <section class="grid gap-6 lg:grid-cols-2">
    <article class="rounded-xl border border-zinc-200 bg-white p-6 shadow-sm">
      <h2 class="mb-4 text-sm font-semibold uppercase tracking-wide text-zinc-500">Source (React + shadcn)</h2>
      <div data-react="shadcn-dialog-demo" class="rounded-lg border border-dashed border-zinc-300 p-6"></div>
    </article>

    <article class="rounded-xl border border-zinc-200 bg-white p-6 shadow-sm">
      <h2 class="mb-4 text-sm font-semibold uppercase tracking-wide text-zinc-500">Converted (Rails + Tailwind + Stimulus)</h2>

      <!-- CODE:converted:start -->
      <div class="rounded-lg border border-dashed border-zinc-300 p-6">
        <button type="button" data-action="dialog-preview#open" class="sc-button sc-button--outline">
          Edit profile
        </button>

        <div data-dialog-preview-target="overlay" data-action="click->dialog-preview#closeOnBackdrop" class="sc-dialog__overlay hidden">
          <div class="sc-dialog__viewport">
            <div role="dialog" aria-modal="true" class="sc-dialog__panel">
              <div class="sc-dialog__header">
                <h3 class="sc-dialog__title">Edit profile</h3>
                <p class="sc-dialog__description">Make changes to your profile here. Click save when you're done.</p>
              </div>

              <div class="sc-dialog__fields">
                <div class="sc-dialog__field">
                  <label for="rails-name" class="sc-dialog__label">Name</label>
                  <input id="rails-name" type="text" value="Pedro Duarte" class="sc-input">
                </div>

                <div class="sc-dialog__field">
                  <label for="rails-username" class="sc-dialog__label">Username</label>
                  <input id="rails-username" type="text" value="@peduarte" class="sc-input">
                </div>
              </div>

              <div class="sc-dialog__actions">
                <button type="button" data-action="dialog-preview#close" class="sc-button sc-button--outline">
                  Cancel
                </button>
                <button type="button" class="sc-button sc-button--default">
                  Save changes
                </button>
              </div>
            </div>
          </div>
        </div>
      </div>
      <!-- CODE:converted:end -->
    </article>
  </section>

  <section class="mt-6 grid gap-6 lg:grid-cols-2">
    <%= render "shared/code_panel", title: "Source Code (React)", code: @source_code %>
    <%= render "shared/code_panel", title: "Converted Code (ERB)", code: @converted_code %>
  </section>
</main>
