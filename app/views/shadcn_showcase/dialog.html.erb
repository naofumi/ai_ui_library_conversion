<main class="mx-auto max-w-7xl px-6 py-10" data-controller="dialog-preview" data-action="keydown@window->dialog-preview#closeOnEscape">
  <header class="mb-8">
    <%= link_to "\u2190 Back", root_path, class: "text-sm text-zinc-600 hover:text-zinc-900" %>
    <h1 class="mt-2 text-3xl font-semibold tracking-tight"><%= @component.page_title %></h1>
    <p class="mt-2 text-sm text-zinc-600"><%= @component.page_description %></p>
  </header>

  <section class="grid gap-6 lg:grid-cols-2">
    <article class="rounded-xl border border-zinc-200 bg-white p-6 shadow-sm">
      <h2 class="mb-4 text-sm font-semibold uppercase tracking-wide text-zinc-500">Source (React + shadcn)</h2>
      <div data-react="shadcn-dialog-demo" class="rounded-lg border border-dashed border-zinc-300 p-6"></div>
    </article>

    <article class="rounded-xl border border-zinc-200 bg-white p-6 shadow-sm">
      <h2 class="mb-4 text-sm font-semibold uppercase tracking-wide text-zinc-500">Converted (Rails + Tailwind + Stimulus)</h2>

      <button type="button" data-action="dialog-preview#open" class="c-button c-button--default">
        Edit profile
      </button>

      <div data-dialog-preview-target="overlay" data-action="click->dialog-preview#closeOnBackdrop" class="c-dialog__overlay hidden">
        <div class="c-dialog__viewport">
          <div role="dialog" aria-modal="true" class="c-dialog__panel">
            <button type="button" data-action="dialog-preview#close" aria-label="Close dialog" class="c-dialog__icon-close">
              ×
            </button>

            <div class="c-dialog__header">
              <h3 class="c-dialog__title">Edit profile</h3>
              <p class="c-dialog__description">Make changes to your profile here. Click save when you're done.</p>
            </div>

            <div class="c-dialog__fields">
              <div class="c-dialog__field">
                <label for="rails-name" class="c-dialog__label">Name</label>
                <input id="rails-name" type="text" value="Pedro Duarte" class="c-input">
              </div>

              <div class="c-dialog__field">
                <label for="rails-username" class="c-dialog__label">Username</label>
                <input id="rails-username" type="text" value="@peduarte" class="c-input">
              </div>
            </div>

            <div class="c-dialog__actions">
              <button type="button" data-action="dialog-preview#close" class="c-button c-button--outline">
                Cancel
              </button>
              <button type="button" data-action="dialog-preview#close" class="c-button c-button--default">
                Save changes
              </button>
            </div>
          </div>
        </div>
      </div>
    </article>
  </section>
</main>
