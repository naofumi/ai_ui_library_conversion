<section class="rounded-xl border border-zinc-200 bg-white p-6 shadow-sm" data-controller="copy-code">
  <% language = local_assigns[:language] || showcase_code_language_from_title(title) %>
  <% highlighted_code = highlight_showcase_code(code, language) %>

  <div class="mb-3 flex items-center justify-between gap-3">
    <h3 class="text-sm font-semibold uppercase tracking-wide text-zinc-500"><%= title %></h3>
    <div class="flex items-center gap-2">
      <span data-copy-code-target="status" class="hidden text-xs font-medium text-zinc-600"></span>
      <button type="button" data-action="copy-code#copy" class="rounded-md border border-zinc-200 bg-white px-2.5 py-1.5 text-xs font-medium text-zinc-900 shadow-xs hover:bg-zinc-100">
        Copy
      </button>
    </div>
  </div>

  <pre class="code-block overflow-x-auto rounded-lg border border-zinc-200 bg-zinc-950 p-4 text-xs leading-5 text-zinc-100"><code class="highlight" data-copy-code-target="source"><%= raw(highlighted_code) %></code></pre>
</section>
