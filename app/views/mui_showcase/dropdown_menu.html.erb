<main class="mx-auto max-w-7xl px-6 py-10">
  <header class="mb-8">
    <%= link_to "\u2190 Back", mui_path, class: "text-sm text-zinc-600 hover:text-zinc-900" %>
    <h1 class="mt-2 text-3xl font-semibold tracking-tight"><%= @component.page_title %></h1>
    <p class="mt-2 text-sm text-zinc-600"><%= @component.page_description %></p>
  </header>

  <section class="grid gap-6 lg:grid-cols-2">
    <article class="rounded-xl border border-zinc-200 bg-white p-6 shadow-sm">
      <h2 class="mb-4 text-sm font-semibold uppercase tracking-wide text-zinc-500">Source (React + MUI)</h2>
      <div data-react="mui-dropdown-menu-demo" class="rounded-lg border border-dashed border-zinc-300 p-6"></div>
    </article>

    <article class="rounded-xl border border-zinc-200 bg-white p-6 shadow-sm">
      <h2 class="mb-4 text-sm font-semibold uppercase tracking-wide text-zinc-500">Converted (Rails + Tailwind + Stimulus)</h2>

      <div data-controller="dropdown-menu-preview" class="mu-dropdown-menu">
        <button
          type="button"
          data-action="dropdown-menu-preview#toggle"
          data-dropdown-menu-preview-target="trigger"
          class="mu-dropdown-menu__trigger"
          aria-controls="mu-dropdown-menu-content"
          aria-haspopup="true"
        >
          Open menu
        </button>

        <div
          id="mu-dropdown-menu-content"
          data-dropdown-menu-preview-target="content"
          class="mu-dropdown-menu__content hidden"
          role="menu"
        >
          <div class="mu-dropdown-menu__label">My Account</div>

          <button type="button" data-action="dropdown-menu-preview#close" class="mu-dropdown-menu__item" role="menuitem">
            Profile
          </button>
          <button type="button" data-action="dropdown-menu-preview#close" class="mu-dropdown-menu__item" role="menuitem">
            Billing
          </button>
          <button type="button" data-action="dropdown-menu-preview#close" class="mu-dropdown-menu__item" role="menuitem">
            Settings
          </button>

          <div class="mu-dropdown-menu__separator"></div>

          <button type="button" data-action="dropdown-menu-preview#close" class="mu-dropdown-menu__item" role="menuitem">
            Log out
          </button>
        </div>
      </div>
    </article>
  </section>
</main>
