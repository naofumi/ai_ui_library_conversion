<main class="mx-auto max-w-7xl px-6 py-10">
  <header class="mb-8">
    <%= link_to "\u2190 Back", root_path, class: "text-sm text-zinc-600 hover:text-zinc-900" %>
    <h1 class="mt-2 text-3xl font-semibold tracking-tight">Card Conversion</h1>
    <p class="mt-2 text-sm text-zinc-600">Compare shadcn card slot structure and spacing.</p>
  </header>

  <section class="grid gap-6 lg:grid-cols-2">
    <article class="rounded-xl border border-zinc-200 bg-white p-6 shadow-sm">
      <h2 class="mb-4 text-sm font-semibold uppercase tracking-wide text-zinc-500">Source (React + shadcn)</h2>
      <div data-react="shadcn-card-demo" class="rounded-lg border border-dashed border-zinc-300 p-6"></div>
    </article>

    <article class="rounded-xl border border-zinc-200 bg-white p-6 shadow-sm">
      <h2 class="mb-4 text-sm font-semibold uppercase tracking-wide text-zinc-500">Converted (Rails + Tailwind)</h2>
      <div class="flex max-w-sm flex-col gap-6 rounded-xl border border-zinc-200 bg-white py-6 shadow-sm">
        <div class="grid auto-rows-min grid-rows-[auto_auto] items-start gap-1.5 px-6">
          <h3 class="leading-none font-semibold">Card Title</h3>
          <p class="text-sm text-zinc-500">Card description text that explains content at a glance.</p>
        </div>

        <div class="px-6">
          <div class="rounded-md border border-zinc-200 bg-zinc-50 p-3 text-sm text-zinc-700">Body content area for converted component parity checks.</div>
        </div>

        <div class="flex items-center justify-end px-6">
          <button type="button" class="inline-flex h-8 items-center justify-center gap-1.5 whitespace-nowrap rounded-md bg-zinc-900 px-3 text-sm font-medium text-white shadow-xs transition-all hover:bg-zinc-800 focus-visible:ring-2 focus-visible:ring-zinc-400">Action</button>
        </div>
      </div>
    </article>
  </section>
</main>
