<main class="mx-auto max-w-7xl px-6 py-10" data-controller="button-preview">
  <header class="mb-8">
    <%= link_to "\u2190 Back", root_path, class: "text-sm text-zinc-600 hover:text-zinc-900" %>
    <h1 class="mt-2 text-3xl font-semibold tracking-tight">Button Conversion</h1>
    <p class="mt-2 text-sm text-zinc-600">Left side uses real shadcn-style React primitives. Right side mirrors the same variants in ERB + Tailwind + Stimulus.</p>
  </header>

  <section class="grid gap-6 lg:grid-cols-2">
    <article class="rounded-xl border border-zinc-200 bg-white p-6 shadow-sm">
      <h2 class="mb-4 text-sm font-semibold uppercase tracking-wide text-zinc-500">Source (React + shadcn)</h2>
      <div data-react="shadcn-button-demo" class="rounded-lg border border-dashed border-zinc-300 p-6"></div>
    </article>

    <article class="rounded-xl border border-zinc-200 bg-white p-6 shadow-sm">
      <h2 class="mb-4 text-sm font-semibold uppercase tracking-wide text-zinc-500">Converted (Rails + Tailwind + Stimulus)</h2>

      <div class="mb-4 flex items-center gap-3">
        <button type="button" data-action="button-preview#toggleDisabled" class="rounded-md border border-zinc-200 bg-white px-3 py-2 text-sm font-medium text-zinc-900 shadow-xs hover:bg-zinc-100">
          Toggle default disabled
        </button>
      </div>

      <div class="flex flex-wrap items-center gap-3">
        <button type="button" data-button-preview-target="button" class="inline-flex h-9 items-center justify-center gap-2 whitespace-nowrap rounded-md bg-zinc-900 px-4 py-2 text-sm font-medium text-white shadow-xs transition-all hover:bg-zinc-800 focus-visible:ring-2 focus-visible:ring-zinc-400 disabled:pointer-events-none disabled:opacity-50">Default</button>
        <button type="button" class="inline-flex h-9 items-center justify-center gap-2 whitespace-nowrap rounded-md bg-zinc-100 px-4 py-2 text-sm font-medium text-zinc-900 shadow-xs transition-all hover:bg-zinc-200 focus-visible:ring-2 focus-visible:ring-zinc-400">Secondary</button>
        <button type="button" class="inline-flex h-9 items-center justify-center gap-2 whitespace-nowrap rounded-md border border-zinc-200 bg-white px-4 py-2 text-sm font-medium text-zinc-900 shadow-xs transition-all hover:bg-zinc-100 focus-visible:ring-2 focus-visible:ring-zinc-400">Outline</button>
        <button type="button" class="inline-flex h-9 items-center justify-center gap-2 whitespace-nowrap rounded-md px-4 py-2 text-sm font-medium text-zinc-900 transition-all hover:bg-zinc-100 focus-visible:ring-2 focus-visible:ring-zinc-400">Ghost</button>
        <button type="button" class="inline-flex h-9 items-center justify-center gap-2 whitespace-nowrap rounded-md px-4 py-2 text-sm font-medium text-zinc-900 transition-all underline-offset-4 hover:underline focus-visible:ring-2 focus-visible:ring-zinc-400">Link</button>
        <button type="button" class="inline-flex h-9 items-center justify-center gap-2 whitespace-nowrap rounded-md bg-red-600 px-4 py-2 text-sm font-medium text-white shadow-xs transition-all hover:bg-red-500 focus-visible:ring-2 focus-visible:ring-zinc-400">Destructive</button>
      </div>
    </article>
  </section>
</main>
